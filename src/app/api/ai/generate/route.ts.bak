import { NextRequest, NextResponse } from "next/server";

export async function POST(request: NextRequest) {
  try {
    const body = await request.json();
    const { goals, level, equipment, durationWeeks, experience, preferences } = body;

    if (!goals || !level) {
      return NextResponse.json(
        { error: "目标和训练水平是必填项" },
        { status: 400 }
      );
    }

    const apiKey = process.env.ANTHROPIC_API_KEY || process.env.OPENAI_API_KEY;
    const baseUrl = process.env.ANTHROPIC_BASE_URL || process.env.OPENAI_BASE_URL || "https://api.anthropic.com/v1";

    if (!apiKey) {
      // Fallback to local template generation
      return generateLocalPlan(body);
    }

    return await generateWithAI(body, apiKey, baseUrl);
  } catch (error) {
    console.error("AI Generate error:", error);
    return NextResponse.json(
      { error: "生成失败，请稍后重试" },
      { status: 500 }
    );
  }
}

async function generateWithAI(body: any, apiKey: string, baseUrl: string) {
  const { goals, level, equipment, durationWeeks, experience, preferences } = body;

  const systemPrompt = `你是专业的健身教练和运动科学专家。根据用户提供的信息，生成一个结构化、可执行的训练计划。
输出格式必须是纯 JSON，不要包含任何 markdown 标记或其他文字。JSON 结构如下：
{
  "program": {
    "name": "计划名称",
    "description": "计划描述",
    "weeks": 周数,
    "phases": [
      {
        "phase": "阶段名称",
        "weeks": [起始周, 结束周],
        "focus": "训练重点",
        "weeklySchedule": [
          {
            "day": "星期几",
            "workoutType": "训练类型",
            "exercises": [
              {
                "name": "动作名称",
                "muscleGroup": "肌肉群",
                "sets": 组数,
                "reps": "次数范围如 10-12",
                "restSeconds": 休息秒数,
                "notes": "注意事项"
              }
            ]
          }
        ]
      }
    ],
    "tips": ["建议1", "建议2", "建议3"]
  }
}

要求：1. 动作选择要科学，符合训练水平
2. 每组次数和重量递增
3. 包含热身和放松环节
4. 考虑可用器械
5. 中文输出`;

  const userPrompt = `请为以下情况生成训练计划：
- 目标：${goals}
- 训练水平：${level}
- 可用器械：${equipment?.join(", ") || "自重"}
- 计划时长：${durationWeeks || 8}周
- 经验：${experience || "无"}
- 偏好：${preferences || "无"}`;

  const response = await fetch(`${baseUrl}/chat/completions`, {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "Authorization": "Bearer " + apiKey,
    },
    body: JSON.stringify({
      model: "agnes-2.0-flash",
      messages: [
        { role: "system", content: systemPrompt },
        { role: "user", content: userPrompt },
      ],
      temperature: 0.7,
      max_tokens: 4000,
    }),
  });

  if (!response.ok) {
    const error = await response.json();
    console.error("AI API error:", error);
    return NextResponse.json(
      { error: "AI 服务调用失败，请稍后重试" },
      { status: 502 }
    );
  }

  const data = await response.json();
  const content = data.choices?.[0]?.message?.content || "";

  let parsedPlan;
  try {
    let jsonStr = content.trim();
    // Strip markdown code blocks
    jsonStr = jsonStr.replace(/`(?:json)?\n?/g, "").replace(/`$/g, "").trim();
    // Try to find JSON object
    const braceMatch = jsonStr.match(/\{[\s\S]*\}/);
    if (!braceMatch) throw new Error("No JSON object found");
    jsonStr = braceMatch[0];
    parsedPlan = JSON.parse(jsonStr);
    // Normalize: ensure we have program.phases
    if (parsedPlan.program && parsedPlan.program.phases) {
      // Already correct format
    } else if (parsedPlan.phases) {
      // Has phases at top level
      parsedPlan = { program: parsedPlan };
    } else if (parsedPlan.program && !parsedPlan.program.phases) {
      // Has program but no phases
      console.warn("[AI] Generated plan has no phases field");
    }
  } catch (e: any) {
    console.error("[AI] Parse error:", e.message);
    parsedPlan = { rawContent: content };
  }
  return NextResponse.json({ plan: parsedPlan });
  return NextResponse.json({ plan: parsedPlan });
}

