  const phases = phaseTemplates[goals] || defaultTemplate;

  const plan = {
    program: {
      name: `${goals}_${levelMap[level] || level}_训练计划`,
      description: `专为${levelMap[level] || level}水平设计的${goals}方案，使用${equipmentList}，周期${weeks}周`,
