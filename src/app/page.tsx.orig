function Stat({ number, label }: { number: string; label: string }) {
  return (<div><div className="text-3xl font-bold text-gray-900">{number}</div><div className="text-sm text-gray-500 mt-1">{label}</div></div>);
}

function Feature({ icon, color, title, desc }: { icon: React.ReactNode; color: string; title: string; desc: string }) {
